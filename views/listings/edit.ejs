<% layout("/layouts/boilerplate") %>
<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Listing - Stayora</title>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=Lato:wght@300;400;700&display=swap" rel="stylesheet">

    <style>

        *{
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root{
            --primary: #2d5a6c;
            --accent: #d4a574;
            --text: #1a1a1a;
            --text-light: #666;
            --bg: #fafaf8;
            --input-border: #e0ddd9;
            --success: #28a745;
            --danger: #dc3545;
        }

        body{
            font-family: 'Lato', sans-serif;
            background: linear-gradient(135deg, #fafaf8 0%, #f3f1ed 100%);
            color: var(--text);
            line-height: 1.6;
        }

        nav{
            background: white;
            box-shadow: 0 2px 8px rgba(0,0,0,0.06);

            position: sticky;
            top: 0;
            z-index: 100;
        }

        .nav-container{
            max-width: 1200px;
            margin: 0 auto;

            padding: 1.5rem 2rem;

            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .logo{
            font-family: 'Playfair Display', serif;
            font-size: 1.8rem;
            font-weight: 700;
            color: var(--primary);
            letter-spacing: -0.5px;
        }

        .nav-link{
            color: var(--text-light);
            text-decoration: none;
            font-size: 0.95rem;
            transition: color 0.3s ease;
        }

        .nav-link:hover{
            color: var(--accent);
        }

        .container{
            max-width: 800px;

            margin: 4rem auto;

            padding: 0 2rem;
        }

        .page-header{
            text-align: center;
            margin-bottom: 3rem;
            opacity: 0;
            animation: fadeInDown 0.6s ease forwards;
        }

        .page-header h1{
            font-family: 'Playfair Display', serif;
            font-size: 2.8rem;
            font-weight: 700;
            color: var(--primary);
            margin-bottom: 0.5rem;
            letter-spacing: -0.5px;
        }

        .page-header p{
            color: var(--text-light);
            font-size: 1.1rem;
            font-weight: 300;
        }

        .form-card{
            background: white;

            border-radius: 12px;

            padding: 3rem;

            box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08);
            opacity: 0;
            animation: fadeInUp 0.8s ease 0.2s forwards;
        }

        .form-card.has-errors {
            box-shadow: 0 4px 20px rgba(220, 53, 69, 0.15);
            border: 1px solid rgba(220, 53, 69, 0.1);
        }

        .form-group{
            margin-bottom: 2.5rem;
            display: flex;
            flex-direction: column;
            position: relative;
        }

        .form-group:last-of-type {
            margin-bottom: 0;
        }

        label{
            display: block;

            margin-bottom: 0.75rem;

            font-weight: 700;

            color: var(--primary);
            font-size: 0.95rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input,
        textarea{
            width: 100%;

            padding: 1rem;

            border: 2px solid var(--input-border);

            border-radius: 8px;

            font-family: 'Lato', sans-serif;
            font-size: 1rem;

            color: var(--text);
            background: #fafaf8;
            transition: all 0.3s ease;
        }

        input:focus,
        textarea:focus{
            outline: none;

            border-color: var(--accent);

            background: white;
            box-shadow: 0 0 0 3px rgba(212, 165, 116, 0.1);
        }

        /* Valid State Styles */
        input.is-valid,
        textarea.is-valid {
            border-color: var(--success) !important;
            background: white;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

        input.is-valid:focus,
        textarea.is-valid:focus {
            border-color: var(--success) !important;
            box-shadow: 0 0 0 3px rgba(40, 167, 69, 0.1);
        }

        /* Invalid State Styles */
        input.is-invalid,
        textarea.is-invalid {
            border-color: var(--danger) !important;
            background: white;
            box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.1);
        }

        input.is-invalid:focus,
        textarea.is-invalid:focus {
            border-color: var(--danger) !important;
            box-shadow: 0 0 0 3px rgba(220, 53, 69, 0.1);
        }

        /* Feedback Messages */
        .valid-feedback {
            display: none;
            width: 100%;
            margin-top: 0.5rem;
            font-size: 0.875rem;
            color: var(--success);
            font-weight: 500;
        }

        .invalid-feedback {
            display: none;
            width: 100%;
            margin-top: 0.5rem;
            font-size: 0.875rem;
            color: var(--danger);
            font-weight: 600;
        }

        /* Show valid feedback when field has is-valid class */
        input.is-valid ~ .valid-feedback,
        textarea.is-valid ~ .valid-feedback {
            display: block;
        }

        /* Show invalid feedback when field has is-invalid class */
        input.is-invalid ~ .invalid-feedback,
        textarea.is-invalid ~ .invalid-feedback {
            display: block !important;
        }

        textarea{
            min-height: 140px;

            resize: vertical;
            font-size: 0.95rem;
        }

        .submit-btn{
            width: 100%;

            padding: 1.2rem;

            border: none;

            border-radius: 8px;

            background: linear-gradient(135deg, var(--primary), #1f3f4d);

            color: white;

            font-size: 1rem;

            font-weight: 700;

            text-transform: uppercase;
            letter-spacing: 1px;

            cursor: pointer;

            transition: all 0.3s ease;
            margin-top: 1rem;
            box-shadow: 0 4px 15px rgba(45, 90, 108, 0.2);
            opacity: 0;
            animation: fadeInUp 0.8s ease 0.4s forwards;
        }

        .submit-btn:hover{
            transform: translateY(-2px);
            box-shadow: 0 6px 25px rgba(45, 90, 108, 0.3);
        }

        .submit-btn:active {
            transform: translateY(0);
        }

        @keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @media(max-width:768px){

            .form-card{
                padding: 2rem;
            }

            .page-header h1{
                font-size: 2rem;
            }

            .form-group {
                margin-bottom: 1.5rem;
            }

            .nav-container {
                padding: 1rem 1.5rem;
            }

            .logo {
                font-size: 1.4rem;
            }
        }

        @media(max-width:480px){

            .container {
                padding: 0 1rem;
            }

            .form-card{
                padding: 1.5rem;
            }

            .page-header h1{
                font-size: 1.8rem;
            }

            input,
            textarea {
                padding: 0.85rem;
                font-size: 16px;
            }

            label {
                font-size: 0.85rem;
            }
        }

    </style>

</head>

<body>

    <nav>

        <div class="nav-container">

            <div class="logo">
                Stayora
            </div>

            <a href="/" class="nav-link">
                ← Back to Home
            </a>

        </div>

    </nav>

    <div class="container">

        <div class="page-header">

            <h1>Edit the Listing</h1>

            <p>
                Update your property information
            </p>

        </div>

        <form
            method="POST"
            action="/listings/<%= listing._id %>?_method=PUT"
            class="form-card"
            id="editForm"
        >

            <div class="form-group">

                <label for="title">
                    Property Title
                </label>

                <input
                    id="title"
                    name="listing[title]"
                    value="<%= listing.title %>"
                    type="text"
                    required
                />

                <div class="valid-feedback">
                    Title looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter a title.
                </div>

            </div>

            <div class="form-group">

                <label for="description">
                    Description
                </label>

                <textarea
                    id="description"
                    name="listing[description]"
                    required
                ><%= listing.description %></textarea>

                <div class="valid-feedback">
                    Description looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter a description.
                </div>

            </div>

            <div class="form-group">

                <label for="image">
                    Property Image URL
                </label>

                <input
                    id="image"
                    name="listing[image][url]"
                    value="<%= listing.image.url %>"
                    type="text"
                />

                <div class="valid-feedback">
                    Image URL looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter a valid image URL.
                </div>

            </div>

            <div class="form-group">

                <label for="country">
                    Country
                </label>

                <input
                    id="country"
                    name="listing[country]"
                    value="<%= listing.country %>"
                    type="text"
                    required
                />

                <div class="valid-feedback">
                    Country looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter a country.
                </div>

            </div>

            <div class="form-group">

                <label for="location">
                    City / Area
                </label>

                <input
                    id="location"
                    name="listing[location]"
                    value="<%= listing.location %>"
                    type="text"
                    required
                />

                <div class="valid-feedback">
                    Location looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter a location.
                </div>

            </div>

            <div class="form-group">

                <label for="price">
                    Price Per Night (USD)
                </label>

                <input
                    id="price"
                    name="listing[price]"
                    value="<%= listing.price %>"
                    type="number"
                    step="0.01"
                    min="0"
                    required
                />

                <div class="valid-feedback">
                    Price looks good!
                </div>
                <div class="invalid-feedback">
                    Please enter a valid price.
                </div>

            </div>

            <button type="submit" class="submit-btn">
                Update Listing
            </button>

        </form>

    </div>

    <script>
        const form = document.getElementById('editForm');

        // Get all input and textarea elements
        const allFields = form.querySelectorAll('input, textarea');

        // Add event listeners for real-time validation
        allFields.forEach(field => {
            field.addEventListener('input', function() {
                validateField(this);
            });

            field.addEventListener('change', function() {
                validateField(this);
            });

            field.addEventListener('blur', function() {
                validateField(this);
            });
        });

        // Function to validate a single field
        function validateField(field) {
            // Only validate required fields
            if (!field.hasAttribute('required')) {
                return true;
            }

            // Get the value
            let value = field.value.trim();
            let isValid = false;

            // Clear previous validation classes
            field.classList.remove('is-valid', 'is-invalid');

            // Validate based on field type
            if (field.type === 'number') {
                // For number inputs, check if it's a valid positive number
                let numValue = parseFloat(value);
                if (!isNaN(numValue) && numValue >= 0 && value !== '') {
                    isValid = true;
                }
            } else {
                // For text and textarea, just check if not empty
                if (value !== '' && value.length > 0) {
                    isValid = true;
                }
            }

            // Apply validation class
            if (isValid) {
                field.classList.add('is-valid');
            } else {
                field.classList.add('is-invalid');
            }

            return isValid;
        }

        // Form submission handler
        form.addEventListener('submit', function(e) {
            e.preventDefault();
            e.stopPropagation();

            let formIsValid = true;

            // Validate every required field
            allFields.forEach(field => {
                if (field.hasAttribute('required')) {
                    // Clear classes first
                    field.classList.remove('is-valid', 'is-invalid');

                    // Get value
                    let value = field.value.trim();
                    let fieldIsValid = false;

                    // Validate based on field type
                    if (field.type === 'number') {
                        let numValue = parseFloat(value);
                        if (!isNaN(numValue) && numValue >= 0 && value !== '') {
                            fieldIsValid = true;
                            field.classList.add('is-valid');
                        } else {
                            fieldIsValid = false;
                            field.classList.add('is-invalid');
                        }
                    } else {
                        if (value !== '' && value.length > 0) {
                            fieldIsValid = true;
                            field.classList.add('is-valid');
                        } else {
                            fieldIsValid = false;
                            field.classList.add('is-invalid');
                        }
                    }

                    // Update overall form validity
                    if (!fieldIsValid) {
                        formIsValid = false;
                    }
                }
            });

            // If form is valid, submit it
            if (formIsValid) {
                form.classList.remove('has-errors');
                console.log('Form is valid! Submitting...');
                form.submit();
            } else {
                form.classList.add('has-errors');
                console.log('Form has errors! Please fill all required fields.');
                alert('❌ Please fill in ALL required fields!\n\nCheck the red error messages below.');
            }
        });
    </script>

</body>

</html>